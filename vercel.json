{
  "redirects": [
    {
      "source": "/",
      "destination": "/ca/editions/spring2026",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/:path*/api/:rest*",
      "destination": "https://www.shopify.com/:path*/api/:rest*"
    },
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ]
}
